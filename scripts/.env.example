# Cloud Pipeline — Environment Variables
# Copy this to .env and fill in your keys

# Replicate API token (https://replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=r8_...

# fal.ai API key (https://fal.ai/dashboard/keys)
FAL_KEY=...

# HuggingFace token (required by mmezhov/catvton-flux for FLUX.1-dev)
# Create at https://huggingface.co/settings/token (write token)
# Must accept FLUX.1-dev license terms first:
#   https://huggingface.co/black-forest-labs/FLUX.1-dev
HF_TOKEN=hf_...

# Optional: ComfyUI Cloud API key (https://cloud.comfy.org)
# COMFY_CLOUD_API_KEY=...
